# ─────────────────────────────────────────────────────────────────────
#  TorchMail Search Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────
#  Pick ONE of the hosted providers below (all have free tiers) or
#  use the local docker-compose.yml fallback.
#
#  Supabase  (recommended) — https://supabase.com
#    1. Create a project at https://app.supabase.com
#    2. Go to Settings → Database → Connection string → URI
#    3. Paste it below (replace [YOUR-PASSWORD] with your DB password)
#
#  Neon  — https://neon.tech
#    1. Create a project at https://console.neon.tech
#    2. Copy the connection string from the dashboard
#
#  Local Docker (optional fallback):
#    docker compose up -d
#    DATABASE_URL=postgresql://torchmail:torchmail_dev@localhost:5432/torchmail

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.kladhymmcqkaezikjhen.supabase.co:5432/postgres

# ── OpenAlex API ─────────────────────────────────────────────────────
#  Optional. Adding your email gives you the "polite" pool (faster).
#  https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=

# ── Cache ────────────────────────────────────────────────────────────
#  How long search results are cached before a fresh API call, in hours.
CACHE_TTL_HOURS=24

#  How long scraped hiring paragraphs stay active before re-scraping, in days.
HIRING_SIGNAL_TTL_DAYS=7

# ── Frontend (optional) ──────────────────────────────────────────────
# For deployed frontend builds when backend runs on another origin.
# VITE_API_BASE_URL=https://your-backend.example.com

# ── Backend CORS (optional) ───────────────────────────────────────────
# Comma-separated origins allowed by FastAPI CORS middleware.
# BACKEND_CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
