# ─────────────────────────────────────────────────────────────────────
#  TorchMail Search Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────
#  Pick ONE connection mode below.  Railway + Supabase requires the
#  Session Pooler URL (IPv4).  The direct connection uses IPv6 by
#  default on new Supabase projects and may time-out on Railway.
#
#  Supabase — recommended connection modes:
#
#  A) Session Pooler  ← use this for Railway (IPv4, SQLAlchemy-safe)
#     Dashboard: Project → Connect → Session pooler
#     Host:  aws-0-<region>.pooler.supabase.com  Port: 5432
#     User:  postgres.<project-ref>
#
#  B) Direct connection  (IPv6 — needs "IPv4 Add-On" in Supabase if Railway can't reach it)
#     Dashboard: Project → Connect → Direct connection
#     Host:  db.<project-ref>.supabase.co  Port: 5432
#     User:  postgres
#
#  C) Transaction Pooler  (port 6543 — NOT recommended: breaks prepared statements)
#
#  Neon  — https://neon.tech (alternative, always IPv4 via pooled URL)
#    Use the pooled connection string from the Neon dashboard.
#
#  Local Docker fallback:
#    docker compose up -d
#    DATABASE_URL=postgresql://torchmail:torchmail_dev@localhost:5432/torchmail

# Session Pooler URL (recommended for Railway):
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# Direct URL (use if Railway supports IPv6 in your region, or with Supabase IPv4 Add-On):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# ── OpenAlex API ─────────────────────────────────────────────────────
#  Optional. Adding your email gives you the "polite" pool (faster).
#  https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=

# ── Cache ────────────────────────────────────────────────────────────
#  How long search results are cached before a fresh API call, in hours.
CACHE_TTL_HOURS=24

#  How long scraped hiring paragraphs stay active before re-scraping, in days.
HIRING_SIGNAL_TTL_DAYS=7

# ── Frontend (optional) ──────────────────────────────────────────────
# For deployed frontend builds when backend runs on another origin.
# VITE_API_BASE_URL=https://your-backend.example.com

# ── Backend CORS (optional) ───────────────────────────────────────────
# Comma-separated origins allowed by FastAPI CORS middleware.
# BACKEND_CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
